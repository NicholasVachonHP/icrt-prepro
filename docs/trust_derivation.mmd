%% Gold per-field trust derivation (contract_field_evidence.trust)
%% Logic source: src/contract_intelligence/gold/evidence.py
%%   derive_trust()  = base trust (Step A) then two downgrade gates (Step B)
%%   _judge_trust()  = Step A
%% Plan 01 added the type_validation gate; Plan 02 added the source_verified gate.
flowchart TD
    START([Field value + evidence quote]) --> V{value is null?}
    V -->|yes| UNK[[unknown]]
    V -->|no| ERR

    subgraph stepA["Step A — base trust (quote match + LLM judge)"]
        direction TB
        ERR{judge errored?} -->|yes| R1[review]
        ERR -->|no| JEN{judge enabled<br/>AND verdict present?}
        JEN -->|no| L1{quote located?<br/>exact / normalized / fuzzy}
        L1 -->|yes| R2[review]
        L1 -->|no| U1[unknown]
        JEN -->|yes| VER{judge_verdict}
        VER -->|incorrect| LOW[low]
        VER -->|partial| R3[review]
        VER -->|unverifiable| U2[unknown]
        VER -->|correct| L2{quote located?}
        L2 -->|no| R4[review]
        L2 -->|yes| HIGH[high]
    end

    %% --- Step B: gates only ever downgrade a base 'high' to 'review' ---
    HIGH --> G1{type_validation<br/>== invalid?}
    G1 -->|yes| RG[review]
    G1 -->|no| G2{source_verified<br/>== low?}
    G2 -->|yes| RG
    G2 -->|no| HFINAL[[high]]

    %% non-high base trusts bypass the gates unchanged
    LOW --> LFINAL[[low]]
    R1 --> RFINAL[[review]]
    R2 --> RFINAL
    R3 --> RFINAL
    R4 --> RFINAL
    RG --> RFINAL
    U1 --> UNK
    U2 --> UNK

    %% --- How source_verified (the Step-B gate input) is set ---
    subgraph sv["source_verified (Source→DI fidelity, Plan 02)"]
        direction TB
        SV0{DI evidence-span confidence}
        SV0 -->|span conf &lt; threshold<br/>OR di_quality_flag == low| SVL[low]
        SV0 -->|span conf OK| SVH[high]
        SVL -.->|vision: confirmed| SVC[confirmed]
        SVH -.->|vision: confirmed| SVC
        SVL -.->|vision: contradicted| SVL
        SVH -.->|vision: contradicted| SVL2[low]
        SVL -.->|vision: unclear / disabled| SVL
        SVH -.->|vision: unclear / disabled| SVH
    end
    SVL ==>|feeds| G2
    SVL2 ==>|feeds| G2
    SVH ==>|feeds| G2
    SVC ==>|feeds| G2

    classDef high fill:#c8e6c9,stroke:#2e7d32,color:#1b5e20;
    classDef review fill:#ffe0b2,stroke:#ef6c00,color:#e65100;
    classDef low fill:#ffcdd2,stroke:#c62828,color:#b71c1c;
    classDef unknown fill:#e0e0e0,stroke:#616161,color:#212121;
    class HFINAL,HIGH,SVH,SVC high;
    class RFINAL,R1,R2,R3,R4,RG review;
    class LFINAL,LOW,SVL,SVL2 low;
    class UNK,U1,U2 unknown;
